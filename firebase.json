    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "real-beauty-2b6b0",
